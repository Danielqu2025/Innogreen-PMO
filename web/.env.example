# =============================================
# Innogreen PMO Web 环境变量配置
# 复制此文件为 .env 并修改实际值
# =============================================

# ============ 数据库 ============
# SQLite 数据库路径（相对于 web/ 目录）
# 开发：../data/innogreen_pmo.db
# 生产：建议使用绝对路径
PMO_DB_PATH=../data/innogreen_pmo.db

# ============ 会话密钥（必填） ============
# 签名会话 cookie 的密钥。未设则后端拒绝启动。
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
# 注意：这是会话安全根基，切勿泄漏、切勿提交真实值到仓库。
PMO_SESSION_SECRET=replace-with-output-of-secrets-token-hex-32

# ============ 首个管理员（可选，冷启动种子） ============
# 仅当 users 表为空时生效，用于建一号管理员；之后在"用户管理"页增删。
# 密码须 ≥8 位，且不能是 change-me-now 等示例/弱值（启动时会拒绝创建）。
PMO_BOOTSTRAP_ADMIN_USERNAME=admin
PMO_BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# ============ 服务配置 ============
# API 服务监听地址（默认仅本机；生产经 nginx 反代，勿改为 0.0.0.0 直接对外）
PMO_HOST=127.0.0.1

# API 服务端口
PMO_PORT=8000

# 是否启用 API 文档（/docs, /redoc）与 OpenAPI schema（/openapi.json）
# 默认 false：Swagger / schema 暴露完整字段名（含 password），是信息泄露面。
# 开发需要时显式打开；生产环境务必保持 false。
PMO_ENABLE_DOCS=false

# 会话 cookie 是否仅 HTTPS 传输（生产 HTTPS 反代后设 true；本地 http 开发保持 false）
PMO_HTTPS_ONLY=false

# CORS 允许的前端地址（多个用逗号分隔；禁止用 '*'，与登录凭据冲突）
# 开发：前端 Vite dev server
# 生产经 Cloudflare Tunnel 或 nginx 反代：必须包含前端公网域（如 https://qcc.dqhermes.kdns.fr）
# 否则 withCredentials=True 的登录凭据会被浏览器拒绝。
PMO_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 是否信任代理头解析真实 IP（X-Forwarded-For / CF-Connecting-IP）。
# 默认 false：客户端可伪造 XFF 绕过 IP 限速。仅在可信反向代理
#（nginx / Cloudflare Tunnel）之后设为 true。
PMO_TRUST_PROXY_HEADER=false
