# =============================================
# Innogreen PMO Web 环境变量配置
# 复制此文件为 .env 并修改实际值
# =============================================

# ============ 数据库 ============
# SQLite 数据库路径（相对于 web/ 目录）
# 开发：../data/innogreen_pmo.db
# 生产：建议使用绝对路径
PMO_DB_PATH=../data/innogreen_pmo.db

# ============ 鉴权（必填） ============
# Bearer Token，用于 API 写入操作的身份验证
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
# 注意：dev-token-change-me 仅用于本地开发，上线前必须修改！
PMO_API_TOKEN=dev-token-change-me

# ============ 服务配置 ============
# API 服务监听地址（默认仅监听本机，内网访问需改为 0.0.0.0）
PMO_HOST=127.0.0.1

# API 服务端口
PMO_PORT=8000

# 是否启用 API 文档（/docs, /redoc）
# 生产环境建议设为 false
PMO_ENABLE_DOCS=true

# CORS 允许的前端地址（多个用逗号分隔）
# 开发：前端 Vite dev server
PMO_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
